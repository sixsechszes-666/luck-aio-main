# =============================================================================
# LuckFlow configuration — copy to `.env` and fill in your own values.
# NEVER commit a real .env. All secrets below are placeholders.
# =============================================================================

# ---- Paths ------------------------------------------------------------------
LUCKFLOW_DATA_DIR=data
LUCKFLOW_RESULT_DIR=result

# ---- Solana -----------------------------------------------------------------
LUCKFLOW_SOLANA__RPC_URL=https://api.mainnet-beta.solana.com
LUCKFLOW_SOLANA__HELIUS_RPC_URL=
LUCKFLOW_SOLANA__TRANSACTION_TIMEOUT=300
LUCKFLOW_SOLANA__BALANCE_CHECK_INTERVAL=1.0
LUCKFLOW_SOLANA__NUM_TEMP_WALLETS=3
LUCKFLOW_SOLANA__USE_MASTER_WALLET=false
LUCKFLOW_SOLANA__ONCHAIN_SPEED_MODE=FAST
LUCKFLOW_SOLANA__ONCHAIN_MAX_RETRIES=5

# ---- Wallet private keys (REQUIRED for on-chain modes) ----------------------
# Base58-encoded secret keys. Leave empty to disable on-chain funding.
LUCKFLOW_MAIN_WALLET_PRIVATE_KEY=
LUCKFLOW_MASTER_WALLET_PRIVATE_KEY=

# ---- SOL funding amounts ----------------------------------------------------
LUCKFLOW_FUNDING__MIN_AMOUNT=0.013
LUCKFLOW_FUNDING__MAX_AMOUNT=0.02
LUCKFLOW_FUNDING__REGISTRATION_MIN=0.012
LUCKFLOW_FUNDING__REGISTRATION_MAX=0.0222
LUCKFLOW_FUNDING__MAX_ATTEMPTS=5
LUCKFLOW_FUNDING__ENABLED=true

# ---- Captcha solver API keys ------------------------------------------------
LUCKFLOW_CAPTCHA__SONIC_API_KEY=your_captcha_sonic_key_here
LUCKFLOW_CAPTCHA__FOX_API_KEY=your_captcha_fox_key_here

# ---- Solflare wallet extension ----------------------------------------------
LUCKFLOW_SOLFLARE__PASSWORD=your_solflare_unlock_password
LUCKFLOW_SOLFLARE__RETURN_WALLET_ADDRESS=

# ---- Browser ----------------------------------------------------------------
LUCKFLOW_BROWSER__MAX_RETRIES=3
LUCKFLOW_BROWSER__RETRY_DELAY=20
LUCKFLOW_BROWSER__TIMEOUT=30000
LUCKFLOW_BROWSER__LOAD_TIMEOUT=40000

# ---- Game tuning ------------------------------------------------------------
LUCKFLOW_GAME__MINES_MIN_ROUNDS=4
LUCKFLOW_GAME__MINES_MAX_ROUNDS=8
LUCKFLOW_GAME__DICE_MIN_ROUNDS=4
LUCKFLOW_GAME__DICE_MAX_ROUNDS=6
LUCKFLOW_GAME__ENABLE_BALANCE_CHECK=true
LUCKFLOW_GAME__MIN_BALANCE=0.11

# ---- Concurrency ------------------------------------------------------------
LUCKFLOW_CONCURRENCY__MAX_WORKERS=3
LUCKFLOW_CONCURRENCY__MAX_WITHDRAW=3
LUCKFLOW_CONCURRENCY__MAX_TIMER_CHECK=3
LUCKFLOW_CONCURRENCY__MAX_ONCHAIN=3

# ---- Daily cooldown ---------------------------------------------------------
LUCKFLOW_DAILY__INTERVAL_HOURS=24
LUCKFLOW_DAILY__COOLDOWN_ENABLED=false

# ---- Withdraw ---------------------------------------------------------------
LUCKFLOW_WITHDRAW__MIN_BALANCE_TO_START=0.35
LUCKFLOW_WITHDRAW__KEEP_MIN=0.15
LUCKFLOW_WITHDRAW__KEEP_MAX=0.25
LUCKFLOW_WITHDRAW__IN_DAILY_ENABLED=false
LUCKFLOW_WITHDRAW__DAILY_MIN_BALANCE=1.0
LUCKFLOW_WITHDRAW__DICE_SIDES=6
LUCKFLOW_WITHDRAW__DICE_INCREMENT=random
LUCKFLOW_WITHDRAW__DAILY_TRIGGER=random

# ---- Web dashboard ----------------------------------------------------------
LUCKFLOW_SERVER__HOST=localhost
LUCKFLOW_SERVER__PORT=5000
LUCKFLOW_SERVER__DEBUG=false
LUCKFLOW_SERVER__TUNNEL_ENABLED=false
LUCKFLOW_SERVER__DASHBOARD_SECRET_TOKEN=

# ---- Telegram notifications -------------------------------------------------
LUCKFLOW_TELEGRAM__BOT_TOKEN=
LUCKFLOW_TELEGRAM__USER_ID=

# ---- Misc -------------------------------------------------------------------
LUCKFLOW_DEBUG_MODE=false
LUCKFLOW_SAVE_STATS_EVERY_N=5
